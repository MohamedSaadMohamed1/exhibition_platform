rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================
    // HELPER FUNCTIONS
    // ========================

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Get current user ID
    function currentUserId() {
      return request.auth.uid;
    }

    // ---------------------------------------------------------------------------
    // Role helpers use Firebase Auth custom claims (set by setRoleClaimsOnUserWrite
    // Cloud Function) so NO extra Firestore read is required per rule evaluation.
    //
    // Fallback: if the token doesn't carry a role claim yet (e.g. first login
    // before the function fires), fall back to a Firestore document read so the
    // app never hard-locks users on the first session after migration.
    // ---------------------------------------------------------------------------

    // Get user document (fallback only — prefer custom claims)
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(currentUserId())).data;
    }

    // Check user role — custom claim first, Firestore fallback.
    // request.auth.token.get('role', null) returns null if the claim isn't set yet
    // (e.g. first login before the Cloud Function fires). Falls back to Firestore read.
    function hasRole(role) {
      return isAuthenticated() && (
        request.auth.token.get('role', null) != null
          ? request.auth.token.role == role
          : getUserData().role == role
      );
    }

    // Check if user is admin
    function isAdmin() {
      return hasRole('admin');
    }

    // Check if user is organizer
    function isOrganizer() {
      return hasRole('organizer');
    }

    // Check if user is supplier
    function isSupplier() {
      return hasRole('supplier');
    }

    // Check if user is exhibitor
    function isExhibitor() {
      return hasRole('exhibitor');
    }

    // Check if user is visitor
    function isVisitor() {
      return hasRole('visitor');
    }

    // Check if user is active
    function isActiveUser() {
      return isAuthenticated() && getUserData().isActive == true;
    }

    // ========================
    // USERS COLLECTION
    // ========================
    match /users/{userId} {
      // Anyone authenticated can read user profiles
      allow read: if isAuthenticated();

      // Users can create their own document on first login (visitor only)
      allow create: if isAuthenticated()
        && currentUserId() == userId
        && request.resource.data.role == 'visitor'
        && request.resource.data.createdBy == 'self';

      // Admin can create organizer and supplier accounts
      allow create: if isAdmin()
        && request.resource.data.role in ['organizer', 'supplier']
        && request.resource.data.createdBy == currentUserId();

      // Account migration: user claims an admin-pre-created account (phone verified via Firebase Auth)
      allow create: if isAuthenticated()
        && currentUserId() == userId
        && request.resource.data.role in ['organizer', 'supplier']
        && request.resource.data.phone == request.auth.token.phone_number;

      // Users can update their own profile (except role)
      allow update: if isAuthenticated()
        && currentUserId() == userId
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'createdBy', 'createdAt']));

      // Admin can update any user
      allow update: if isAdmin();

      // Only admin can delete users
      allow delete: if isAdmin();

      // Account migration: user can delete the temporary pre-created doc (matched by phone).
      // Extra guard: only admin-pre-created docs (createdBy != 'self') can be claimed this way.
      allow delete: if isAuthenticated()
        && resource.data.phone == request.auth.token.phone_number
        && resource.data.createdBy != 'self';
    }

    // ========================
    // EVENTS COLLECTION
    // ========================
    match /events/{eventId} {
      // Anyone authenticated can read published events
      allow read: if isAuthenticated()
        && (resource.data.status == 'published' || resource.data.organizerId == currentUserId() || isAdmin());

      // Admin and organizers can create events
      allow create: if isAuthenticated()
        && (isAdmin() || isOrganizer())
        && request.resource.data.organizerId == currentUserId();

      // Organizers can only update/delete their own events
      allow update: if isAuthenticated()
        && (resource.data.organizerId == currentUserId() || isAdmin());

      // Any authenticated user can increment/decrement interestedCount (via interest toggle)
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['interestedCount']);

      allow delete: if isAuthenticated()
        && (resource.data.organizerId == currentUserId() || isAdmin());

      // ========================
      // BOOTHS SUBCOLLECTION
      // ========================
      match /booths/{boothId} {
        // Anyone authenticated can read booths
        allow read: if isAuthenticated();

        // Only event organizer can create/update/delete booths
        allow create, update, delete: if isAuthenticated()
          && (get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == currentUserId() || isAdmin());

        // Visitors and exhibitors can reserve an available booth (booking flow)
        allow update: if isAuthenticated()
          && (isVisitor() || isExhibitor())
          && resource.data.status == 'available'
          && request.resource.data.status == 'reserved'
          && request.resource.data.reservedBy == currentUserId()
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'reservedBy', 'reservedAt', 'updatedAt']);
      }
    }

    // ========================
    // BOOKING REQUESTS COLLECTION
    // ========================
    match /booking_requests/{requestId} {
      // Exhibitors can read their own requests
      // Organizers can read requests for their events
      allow read: if isAuthenticated()
        && (resource.data.exhibitorId == currentUserId()
            || resource.data.organizerId == currentUserId()
            || isAdmin());

      // Exhibitors and visitors can create booking requests
      allow create: if isAuthenticated()
        && (isExhibitor() || isVisitor())
        && request.resource.data.exhibitorId == currentUserId()
        && request.resource.data.status == 'pending';

      // Organizers can approve/reject bookings for their events
      // Exhibitors can cancel their own pending bookings
      allow update: if isAuthenticated()
        && (
          // Organizer updating status
          (resource.data.organizerId == currentUserId()
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['status', 'rejectionReason', 'approvedAt', 'rejectedAt', 'confirmedAt', 'updatedAt']))
          ||
          // Exhibitor cancelling
          (resource.data.exhibitorId == currentUserId()
            && resource.data.status in ['pending', 'approved']
            && request.resource.data.status == 'cancelled')
          ||
          // Admin
          isAdmin()
        );

      // Only admin can delete
      allow delete: if isAdmin();
    }

    // ========================
    // CHATS COLLECTION
    // ========================
    match /chats/{chatId} {
      // Allow reading existing chats (participants only) or checking if a chat exists (resource == null)
      allow get: if isAuthenticated()
        && (resource == null || currentUserId() in resource.data.participants);

      // Allow listing chats (participants only)
      allow list: if isAuthenticated()
        && currentUserId() in resource.data.participants;

      // Allow create if user is one of the participants
      allow create: if isAuthenticated()
        && currentUserId() in request.resource.data.participants;

      // Allow update/delete for participants only
      allow update, delete: if isAuthenticated()
        && currentUserId() in resource.data.participants;

      // ========================
      // MESSAGES SUBCOLLECTION
      // ========================
      match /messages/{messageId} {
        // Only chat participants can read messages
        allow read: if isAuthenticated()
          && currentUserId() in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // Only chat participants can send messages
        allow create: if isAuthenticated()
          && currentUserId() in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.senderId == currentUserId();

        // Allow updating read status
        allow update: if isAuthenticated()
          && currentUserId() in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy', 'readAt']);
      }
    }

    // ========================
    // SUPPLIERS COLLECTION
    // ========================
    match /suppliers/{supplierId} {
      // Anyone authenticated can read active suppliers or their own profile
      // NOTE: isAdmin() removed intentionally — it calls getUserData() (a Firestore get())
      // inside a LIST query rule which can cause permission-denied on the entire query.
      // Admins can still read their own docs; admin-specific reads use the Firebase Console.
      allow read: if isAuthenticated()
        && (resource.data.isActive == true || resource.data.ownerId == currentUserId());

      // Admin can create suppliers; authenticated users can auto-provision their own profile
      // Note: uses request.auth.uid directly to avoid getUserData() race conditions
      allow create: if isAdmin()
        || (isAuthenticated() && request.resource.data.ownerId == request.auth.uid);

      // Supplier owner can update their own profile
      allow update: if isAuthenticated()
        && (resource.data.ownerId == currentUserId() || isAdmin())
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['ownerId', 'createdByAdmin', 'createdAt']));

      // Account migration: allow updating ownerId when user claims their supplier profile (phone verified)
      allow update: if isAuthenticated()
        && resource.data.contactPhone == request.auth.token.phone_number
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ownerId', 'updatedAt']);

      // Only admin can delete
      allow delete: if isAdmin();
    }

    // ========================
    // SERVICES COLLECTION
    // ========================
    match /services/{serviceId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ========================
    // ORDERS COLLECTION
    // ========================
    match /orders/{orderId} {
      allow read, write: if isAuthenticated();
    }

    // ========================
    // EVENT JOBS COLLECTION
    // ========================
    match /jobs/{jobId} {
      // Anyone authenticated can read open jobs
      allow read: if isAuthenticated();

      // Only organizers can create jobs for their events
      allow create: if isAuthenticated()
        && (isOrganizer() || isAdmin())
        && request.resource.data.organizerId == currentUserId();

      // Only job creator can update
      allow update: if isAuthenticated()
        && (resource.data.organizerId == currentUserId() || isAdmin());

      // Only admin or job creator can delete
      allow delete: if isAuthenticated()
        && (resource.data.organizerId == currentUserId() || isAdmin());

      // ========================
      // JOB APPLICATIONS SUBCOLLECTION
      // ========================
      match /applications/{applicationId} {
        // Applicant reads their own; organizer reads for their job; admin reads all
        allow read: if isAuthenticated()
          && (resource.data.userId == currentUserId()
              || isAdmin()
              || get(/databases/$(database)/documents/jobs/$(jobId)).data.organizerId == currentUserId());

        // Any authenticated user can apply (applicant sets their own userId)
        allow create: if isAuthenticated()
          && request.resource.data.userId == currentUserId()
          && request.resource.data.status == 'pending';

        // Organizer or admin can update status/feedback
        allow update: if isAuthenticated()
          && (isAdmin()
              || (get(/databases/$(database)/documents/jobs/$(jobId)).data.organizerId == currentUserId()
                  && request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['status', 'feedback', 'reviewedAt', 'updatedAt'])));

        // Applicant can withdraw (delete) their own; admin can delete any
        allow delete: if isAuthenticated()
          && (resource.data.userId == currentUserId() || isAdmin());
      }
    }

    // ========================
    // JOB APPLICATIONS COLLECTION
    // ========================
    match /job_applications/{applicationId} {
      // Admin can read all; applicants read their own
      allow read: if isAuthenticated()
        && (isAdmin() || resource.data.userId == currentUserId());

      // Users can create applications
      allow create: if isAuthenticated()
        && request.resource.data.userId == currentUserId()
        && request.resource.data.status == 'pending';

      // Admin or job creator can update application status
      allow update: if isAuthenticated() && isAdmin();

      // Only admin can delete
      allow delete: if isAdmin();
    }

    // ========================
    // ACCOUNT REQUESTS COLLECTION
    // ========================
    match /account_requests/{requestId} {
      // Users can read their own request; admin can read all
      allow read: if isAuthenticated()
        && (resource.data.userId == currentUserId() || isAdmin());

      // Any authenticated user can create a request for themselves
      allow create: if isAuthenticated()
        && request.resource.data.userId == currentUserId();

      // Only admin can update (approve/reject) or delete
      allow update, delete: if isAdmin();
    }

    // ========================
    // INTERESTS COLLECTION
    // ========================
    match /interests/{interestId} {
      // Users can read/write their own interests
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && request.resource.data.userId == currentUserId();

      allow delete: if isAuthenticated()
        && resource.data.userId == currentUserId();
    }

    // ========================
    // COLLECTION GROUP: applications
    // Required for admin collectionGroup query across all jobs/{jobId}/applications
    // ========================
    match /{path=**}/applications/{applicationId} {
      allow read: if isAdmin();
    }

    // ========================
    // NOTIFICATIONS COLLECTION (if needed)
    // ========================
    match /notifications/{notificationId} {
      allow read: if isAuthenticated()
        && resource.data.userId == currentUserId();

      allow create: if false; // Only Cloud Functions can create

      allow update: if isAuthenticated()
        && resource.data.userId == currentUserId()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);

      allow delete: if isAuthenticated()
        && resource.data.userId == currentUserId();
    }
  }
}
